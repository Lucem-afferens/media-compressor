{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r requirements-vercel.txt",
  "env": {
    "MAX_UPLOAD_MB": "4",
    "MAX_IMAGE_BATCH": "8",
    "MAX_IMAGE_MEGAPIXELS": "20"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
